generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Milestone 8: real multi-user auth (Auth.js v5 + Prisma adapter) ---
// User/Account/Session/VerificationToken match Auth.js's standard Prisma
// adapter schema — Account and Session aren't actively used today (no OAuth
// providers, no database-session reads outside the adapter itself), but the
// adapter's methods reference these Prisma delegates generically regardless
// of which providers are configured, so they need to exist.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Used as the +tag in this user's inbound forwarding address
  // (...+<inboundToken>@inbound.postmarkapp.com) — deliberately NOT the
  // same as `id`. `id` is a cuid, which encodes a timestamp/counter and
  // isn't a fully opaque random value; a public-facing address shouldn't
  // be derived from it. See BUILD.md Milestone 8.
  inboundToken String @unique @default(cuid())

  // Gmail's forwarding-setup confirmation code, surfaced to the user in
  // real time on the setup page (polled via GET /api/gmail-code) so they
  // can complete verification without the owner relaying it manually.
  // Overwritten if a second code arrives before the first is used —
  // accepted alpha trade-off, see TASKS.md. Cleared (both fields to null)
  // once the user confirms they've entered it into Gmail.
  gmailVerificationCode           String?
  gmailVerificationCodeReceivedAt DateTime?

  // Content-free rolling counter for inbound-volume flood detection
  // (lib/adminNotify.ts "inbound_volume_spike"). Approximate fixed-window
  // counter — constantly overwritten, no event history retained. See
  // lib/inboundVolume.ts.
  inboundWindowStart DateTime?
  inboundWindowCount Int       @default(0)

  accounts   Account[]
  sessions   Session[]
  orders     Order[]
  emails     Email[]
  reminders  Reminder[]
  actionLogs ActionLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Email {
  id          String   @id @default(cuid())
  fromEmail   String   // encrypted at rest — see lib/crypto.ts
  fromName    String?  // encrypted at rest
  toHash      String?  // the +tag from the inbound address, identifies the user later
  subject     String?
  textBody    String?  @db.Text // encrypted at rest
  htmlBody    String?  @db.Text // encrypted at rest
  receivedAt  DateTime @default(now())
  rawJson     String   @db.Text // encrypted at rest — whole Postmark payload, JSON-stringified then encrypted

  // --- Milestone 2 additions ---
  retailer            String?
  orderNumber         String?
  orderDate           DateTime?
  deliveryDate        DateTime? // legacy — superseded by estimatedDeliveryDate/deliveredAt below; kept for display fallback on rows predating that split
  // Carrier/shipping-email ETA — never confirmed. Populated whenever a
  // non-"delivery" email states a date (routeDeliveryDate in lib/extract.ts).
  estimatedDeliveryDate DateTime?
  // Only set when emailType is actually "delivery" — a real confirmed
  // delivery, not an estimate. computeDeadline() prefers this over
  // estimatedDeliveryDate whenever both are present.
  deliveredAt         DateTime?
  returnWindowDays    Int? // e.g. 30 — how long the return window is
  returnWindowStartsFrom String? // "order_date" | "delivery_date" | null — what the window counts from
  returnDeadline      DateTime? // computed — see deadline logic in BUILD.md
  deadlineIsEstimated Boolean   @default(false) // true when delivery date was assumed, not confirmed
  policySource        String? // "email" (stated in the email) | "web_lookup" (found via web search)
  confidence          String? // "high" | "medium" | "low"
  emailType           String? // "order_confirmation" | "shipping_confirmation" | "delivery" | "return_label" | "refund" | "other"
  orderTotal          Float? // total order amount, from the email body
  orderCurrency       String? // e.g. "USD"
  refundAmount           Float?  // dollar figure explicitly labeled as the refund amount — distinct from orderTotal; null unless unambiguously stated
  refundAmountConfidence String? // "high" | "medium" | "low" — null iff refundAmount is null
  lineItems           Json? // array of {name, price, quantity}, from the email body
  needsReview         Boolean   @default(false)
  extractionNotes     String?   @db.Text // AI's one-line reasoning, esp. for uncertainty
  extractionRaw       Json? // full AI JSON response, for debugging the prompt
  extractedAt         DateTime?

  // --- Milestone 3 addition ---
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  // --- Milestone 8 addition ---
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Milestone 3: one Order aggregates many Emails about the same purchase ---
model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  retailer    String?
  orderNumber String?

  orderDate           DateTime?
  orderDateEstimated  Boolean   @default(false) // true when orderDate was inferred (forwarded-header parse or receivedAt fallback), not stated in the email
  deliveryDate        DateTime? // legacy — best available across all linked emails; superseded by estimatedDeliveryDate/deliveredAt below, kept for display fallback on rows predating that split
  // Merged (latest non-null wins) across linked emails — see estimatedDeliveryDate/
  // deliveredAt on Email above for what populates these.
  estimatedDeliveryDate DateTime?
  deliveredAt         DateTime?
  returnDeadline       DateTime?
  deadlineIsEstimated  Boolean   @default(false)
  policySource         String? // "web_lookup" | "stated_in_email" | "user_supplied"
  returnWindowDays     Int?
  // --- Milestone 15 addition --- "order_date" | "delivery_date" | null —
  // was already computed during extraction but never persisted, so
  // computeDeadline() could never actually anchor on order_date at the
  // Order level (it always got passed null). See Milestone 15.
  returnWindowStartsFrom String?

  orderTotal      Float?
  orderCurrency   String?
  lineItems       Json?
  returnPortalUrl String? // direct URL to start a return, e.g. mango.com/help/returns

  // "ordered" | "shipped" | "delivered" | "returnable" | "return_started" |
  // "refund_pending" | "completed" | "expired" | "needs_review"
  status      String  @default("ordered")
  needsReview Boolean @default(false)

  // User-facing order status, separate from the internal `status` state machine.
  // Values: "ordered" | "shipped" | "return_requested" | "returned" | "refunded" | "kept"
  // "shipped" auto-derives from shipping_confirmation emails; the others are
  // set via PATCH /api/orders/:id/status or future auto-derivation from email types.
  // Precedence on recompute: refunded > returned > return_requested > shipped > ordered.
  // "kept" is manual-only, never auto-derived, ranked alongside "returned" (see
  // lib/displayStatus.ts) — reachable from ordered/shipped/return_requested, not
  // from returned/refunded.
  // Auto-derivation never downgrades a manually-advanced status.
  displayStatus  String  @default("ordered")

  // Outbound shipment tracking, scraped from shipping_confirmation email bodies.
  carrier        String?
  trackingNumber String?
  trackingUrl    String?

  // Return shipment tracking, scraped from return_label email bodies.
  // Null if no carrier info found — never blocks return_requested status.
  returnCarrier        String?
  returnTrackingNumber String?
  returnTrackingUrl    String?

  // Timestamp of the first transition to displayStatus = "returned". Set once,
  // never reset. Used to compute refund check-in reminder send time (5 or 10
  // days later depending on whether return tracking is present).
  returnedAt DateTime?

  // Timestamp of the (one-way) transition to displayStatus = "kept". Set once,
  // never reset — parallel to returnedAt. Distinct from archivedAt: archivedAt
  // is reversible via unarchive, keptAt is not evidence that can be undone.
  keptAt DateTime?

  // Soft-state fields: null = active; non-null = hidden from all normal views.
  // archivedAt — reversible, user-initiated hiding (no confirm required).
  // deletedAt  — soft delete; hard-deleted by cron after HARD_DELETE_DAYS.
  archivedAt DateTime?
  deletedAt  DateTime?

  // --- Milestone 10 addition --- the user's (or admin's) own explanation
  // when resolving a needsReview flag, via "Looks correct" or "Split into
  // separate order". Not encrypted: it's a note about the user's own
  // order, not retailer/email PII, and the admin dashboard reads it
  // directly without a decrypt step.
  userNote String? @db.Text

  // --- Milestone 8 addition ---
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emails           Email[]
  reminders        Reminder[]
  tokenRedemptions TokenRedemption[]
  actionLogs       ActionLog[]
}

// --- Milestone 4: tracks which reminder emails have already been sent,
// so the daily cron never sends the same one twice ---
// --- Milestone 16 addition: orderId is now optional and userId required,
// since the weekly coverage check (reminderType "weekly_coverage_check")
// is a per-user email with no specific order behind it. The unique
// constraint below only meaningfully applies to per-order reminder types
// (Postgres doesn't treat repeated NULL orderIds as duplicates) — the
// weekly check's own "don't double-send" rule is enforced in code by
// checking for a recent send instead, since its scope is "per user per
// week," not "per order, ever."
model Reminder {
  id      String  @id @default(cuid())
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reminderType String // "7_day" | "2_day" | "1_day" | "same_day" | "weekly_coverage_check"
  sentAt       DateTime @default(now())

  @@unique([orderId, reminderType])
}

// One-tap-from-email (signed action tokens) — enforces single-use. tokenHash
// (not the raw token) is what's stored and uniquely constrained, so the
// single-use check is an atomic DB-level guarantee (a unique-violation on
// insert), not a check-then-write race. orderId is nullable + SetNull on
// delete, same pattern as Reminder above — a hard-deleted Order shouldn't
// block on this audit trail, just orphan it.
model TokenRedemption {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  action    String // "archive" | "returned" | "refunded" | "kept" | "unarchive"
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  redeemedAt DateTime @default(now())
}

// Every token issue/redemption attempt, successful or failed — expired,
// already-used, invalid signature, order-state-changed. userId/orderId are
// both nullable: a sufficiently garbled token may not decode far enough to
// know who or what it was for, and that's still a real event worth logging,
// not a reason to drop the row. Both relations are SetNull on delete, same
// reasoning as TokenRedemption — an audit trail should survive its subject
// being deleted, not silently vanish or block the deletion.
model ActionLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  action    String
  outcome   String // "success" | "expired" | "already_used" | "invalid" | "order_state_changed"
  ipAddress String?
  userAgent String?
  at        DateTime @default(now())
}

// --- Milestone 10: aggregate-only record of non-commerce discards at
// inbound, for the admin "Discard Log" — deliberately no email content
// and no userId, matching the existing discard philosophy (the content
// is never stored; this exists purely to count how often it happens).
model DiscardLog {
  id         String   @id @default(cuid())
  reason     String // "non_commerce" for now; room to add more reasons later
  occurredAt DateTime @default(now())
}

// Marketing-page beta signups, collected pre-auth from myreturnwindow.com.
// Unrelated to User — these are prospects, not accounts.
model BetaSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Alpha-gating allowlist for login, checked in auth.ts before a magic-link
// email is ever sent. Deliberately separate from BetaSignup: these are
// manually-curated invites (e.g. friends invited outside the marketing
// funnel), not marketing-page prospects. An email already belonging to an
// existing User is always allowed to sign in regardless of this table —
// this only gates the FIRST sign-in (account creation), never re-login.
model AllowedSignIn {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  note      String? // optional context, e.g. "friend invite"
}

// Every notifyAdmin() call persists a row here, regardless of outcome —
// deliveryStatus: "sent" | "failed" | "skipped_not_configured" |
// "deduped" (allowlist_rejection notifications collapsed by the 24h dedup
// guard in auth.ts). A String column rather than a Prisma enum: cheap to
// extend as new notification kinds/statuses show up during alpha, and
// nothing here needs DB-level enum enforcement.
// kind: "beta_signup" | "allowlist_rejection" | "new_user_login" |
// "gmail_verification" | "reminder_summary" | "weekly_coverage_summary" |
// "weekly_digest_summary" | "inbound_volume_spike"
model AdminNotification {
  id             String   @id @default(cuid())
  kind           String
  subject        String
  body           String   @db.Text
  relatedEmail   String? // the email this notification is about, when there is one
  deliveryStatus String
  errorMessage   String? // sendEmail's caught error, when deliveryStatus is "failed"
  attemptedAt    DateTime @default(now())
}
