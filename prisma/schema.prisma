generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Milestone 8: real multi-user auth (Auth.js v5 + Prisma adapter) ---
// User/Account/Session/VerificationToken match Auth.js's standard Prisma
// adapter schema — Account and Session aren't actively used today (no OAuth
// providers, no database-session reads outside the adapter itself), but the
// adapter's methods reference these Prisma delegates generically regardless
// of which providers are configured, so they need to exist.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Used as the +tag in this user's inbound forwarding address
  // (...+<inboundToken>@inbound.postmarkapp.com) — deliberately NOT the
  // same as `id`. `id` is a cuid, which encodes a timestamp/counter and
  // isn't a fully opaque random value; a public-facing address shouldn't
  // be derived from it. See BUILD.md Milestone 8.
  inboundToken String @unique @default(cuid())

  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  emails    Email[]
  reminders Reminder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Email {
  id          String   @id @default(cuid())
  fromEmail   String   // encrypted at rest — see lib/crypto.ts
  fromName    String?  // encrypted at rest
  toHash      String?  // the +tag from the inbound address, identifies the user later
  subject     String?
  textBody    String?  @db.Text // encrypted at rest
  htmlBody    String?  @db.Text // encrypted at rest
  receivedAt  DateTime @default(now())
  rawJson     String   @db.Text // encrypted at rest — whole Postmark payload, JSON-stringified then encrypted

  // --- Milestone 2 additions ---
  retailer            String?
  orderNumber         String?
  orderDate           DateTime?
  deliveryDate        DateTime?
  returnWindowDays    Int? // e.g. 30 — how long the return window is
  returnWindowStartsFrom String? // "order_date" | "delivery_date" | null — what the window counts from
  returnDeadline      DateTime? // computed — see deadline logic in BUILD.md
  deadlineIsEstimated Boolean   @default(false) // true when delivery date was assumed, not confirmed
  policySource        String? // "email" (stated in the email) | "web_lookup" (found via web search)
  confidence          String? // "high" | "medium" | "low"
  emailType           String? // "order_confirmation" | "shipping_confirmation" | "delivery" | "return_label" | "refund" | "other"
  orderTotal          Float? // total order amount, from the email body
  orderCurrency       String? // e.g. "USD"
  lineItems           Json? // array of {name, price, quantity}, from the email body
  needsReview         Boolean   @default(false)
  extractionNotes     String?   @db.Text // AI's one-line reasoning, esp. for uncertainty
  extractionRaw       Json? // full AI JSON response, for debugging the prompt
  extractedAt         DateTime?

  // --- Milestone 3 addition ---
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  // --- Milestone 8 addition ---
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Milestone 3: one Order aggregates many Emails about the same purchase ---
model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  retailer    String?
  orderNumber String?

  orderDate           DateTime?
  deliveryDate        DateTime? // best available across all linked emails
  returnDeadline       DateTime?
  deadlineIsEstimated  Boolean   @default(false)
  policySource         String? // "web_lookup" | "stated_in_email" | "user_supplied"
  returnWindowDays     Int?
  // --- Milestone 15 addition --- "order_date" | "delivery_date" | null —
  // was already computed during extraction but never persisted, so
  // computeDeadline() could never actually anchor on order_date at the
  // Order level (it always got passed null). See Milestone 15.
  returnWindowStartsFrom String?

  orderTotal      Float?
  orderCurrency   String?
  lineItems       Json?
  returnPortalUrl String? // direct URL to start a return, e.g. mango.com/help/returns

  // "ordered" | "shipped" | "delivered" | "returnable" | "return_started" |
  // "refund_pending" | "completed" | "expired" | "needs_review"
  status      String  @default("ordered")
  needsReview Boolean @default(false)

  // User-facing order status, separate from the internal `status` state machine.
  // Values: "ordered" | "shipped" | "return_requested" | "returned" | "refunded"
  // "shipped" auto-derives from shipping_confirmation emails; the others are
  // set via PATCH /api/orders/:id/status or future auto-derivation from email types.
  // Precedence on recompute: refunded > returned > return_requested > shipped > ordered.
  // Auto-derivation never downgrades a manually-advanced status.
  displayStatus  String  @default("ordered")

  // Outbound shipment tracking, scraped from shipping_confirmation email bodies.
  carrier        String?
  trackingNumber String?
  trackingUrl    String?

  // Return shipment tracking, scraped from return_label email bodies.
  // Null if no carrier info found — never blocks return_requested status.
  returnCarrier        String?
  returnTrackingNumber String?
  returnTrackingUrl    String?

  // Timestamp of the first transition to displayStatus = "returned". Set once,
  // never reset. Used to compute refund check-in reminder send time (5 or 10
  // days later depending on whether return tracking is present).
  returnedAt DateTime?

  // Soft-state fields: null = active; non-null = hidden from all normal views.
  // archivedAt — reversible, user-initiated hiding (no confirm required).
  // deletedAt  — soft delete; hard-deleted by cron after HARD_DELETE_DAYS.
  archivedAt DateTime?
  deletedAt  DateTime?

  // --- Milestone 10 addition --- the user's (or admin's) own explanation
  // when resolving a needsReview flag, via "Looks correct" or "Split into
  // separate order". Not encrypted: it's a note about the user's own
  // order, not retailer/email PII, and the admin dashboard reads it
  // directly without a decrypt step.
  userNote String? @db.Text

  // --- Milestone 8 addition ---
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emails    Email[]
  reminders Reminder[]
}

// --- Milestone 4: tracks which reminder emails have already been sent,
// so the daily cron never sends the same one twice ---
// --- Milestone 16 addition: orderId is now optional and userId required,
// since the weekly coverage check (reminderType "weekly_coverage_check")
// is a per-user email with no specific order behind it. The unique
// constraint below only meaningfully applies to per-order reminder types
// (Postgres doesn't treat repeated NULL orderIds as duplicates) — the
// weekly check's own "don't double-send" rule is enforced in code by
// checking for a recent send instead, since its scope is "per user per
// week," not "per order, ever."
model Reminder {
  id      String  @id @default(cuid())
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reminderType String // "7_day" | "2_day" | "1_day" | "same_day" | "weekly_coverage_check"
  sentAt       DateTime @default(now())

  @@unique([orderId, reminderType])
}

// --- Milestone 10: aggregate-only record of non-commerce discards at
// inbound, for the admin "Discard Log" — deliberately no email content
// and no userId, matching the existing discard philosophy (the content
// is never stored; this exists purely to count how often it happens).
model DiscardLog {
  id         String   @id @default(cuid())
  reason     String // "non_commerce" for now; room to add more reasons later
  occurredAt DateTime @default(now())
}

// Marketing-page beta signups, collected pre-auth from myreturnwindow.com.
// Unrelated to User — these are prospects, not accounts.
model BetaSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
